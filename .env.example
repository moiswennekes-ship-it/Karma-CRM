# Supabase — get these from your Supabase project dashboard → Settings → API
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Anthropic — get from console.anthropic.com → API Keys
# NOTE: In production, proxy this through a backend or Supabase Edge Function
# to keep your key private. Never expose it in a public frontend.
REACT_APP_ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
